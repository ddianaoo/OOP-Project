@model FoodDelivery.Web.Models.LoginViewModel

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">

                <h3 class="text-center mb-4">Вхід</h3>

                <form asp-action="Login" method="post">

                    <div class="mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Пошта" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Пароль" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button class="btn btn-pink w-100">Увійти</button>

                </form>

                <p class="text-center mt-3">
                    Немає акаунта?
                    <a href="/Auth/Register">Зареєструватися</a>
                </p>

            </div>
        </div>
    </div>
</div>