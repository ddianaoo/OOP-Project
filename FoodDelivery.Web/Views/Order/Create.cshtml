@model CreateOrderViewModel

<div class="container">

    <h2 class="mb-4">📦 Оформлення замовлення</h2>

    <div class="row">

        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">

                    <h5>🛒 Кошик</h5>

                    <ul class="list-group">
                        @foreach (var item in ((Cart)ViewBag.Cart).Items)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@item.Dish?.Name × @item.Quantity</span>
                                <strong>@(item.Quantity * item.Dish?.Price) ₴</strong>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </div>

        <div class="col-md-4">

            <div class="card shadow">
                <div class="card-body">

                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label class="form-label">Адреса доставки</label>

                            <input asp-for="Address" class="form-control" />

                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div asp-validation-summary="All" class="text-danger"></div>

                        <button class="btn btn-pink w-100">
                            Підтвердити
                        </button>

                    </form>

                </div>
            </div>

        </div>

    </div>

</div>