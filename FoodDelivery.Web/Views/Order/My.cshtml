@using FoodDelivery.Domain.Entities
@model List<Order>

<h2 class="mb-4">📦 Мої замовлення</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        У вас ще немає замовлень
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <div class="d-flex justify-content-between mb-2">
                    <strong>Замовлення @order.Id</strong>
                    <span class="badge bg-secondary">@order.Status</span>
                </div>

                <div class="mb-2 text-muted">
                    <i class="bi bi-calendar-week"></i> @order.CreatedAt.ToLocalTime()
                </div>
                <div class="mb-2 text-muted">
                    <i class="bi bi-geo-alt-fill"></i> @order.Address
                </div>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Страва</th>
                            <th>Ціна</th>
                            <th>Кількість</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.Dish?.Name</td>
                                <td>@item.Dish?.Price ₴</td>
                                <td>@item.Quantity</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="text-end fw-bold">
                    Разом: @order.Items.Sum(x => x.Quantity * x.Dish.Price) ₴
                </div>

            </div>
        </div>
    }
}