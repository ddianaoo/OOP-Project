@model FoodDelivery.Web.Models.DishEditViewModel

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-4">

                <h3 class="text-center mb-4"> Редагування страви</h3>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">

                    <input type="hidden" asp-for="Id" />

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3 text-center">
                            <img src="@Model.ImageUrl"
                                 style="max-width:200px; border-radius:12px;" />
                        </div>
                    }
                    <!-- Name -->
                    <div class="mb-3">
                        <input asp-for="Name" class="form-control" placeholder="Назва страви" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <textarea asp-for="Description" class="form-control" placeholder="Опис"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <!-- Price -->
                    <div class="mb-3">
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Ціна" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="ImageFile" type="file" class="form-control" />
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between">
                        <a href="/Dish" class="btn btn-outline-secondary">
                            ← Назад
                        </a>

                        <button type="submit" class="btn btn-pink">
                            Зберегти
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>