@model FoodDelivery.Web.Models.DishCreateViewModel

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body">

                <h3 class="text-center mb-4">Додати страву</h3>

                <form asp-action="Create" method="post" enctype="multipart/form-data">

                    <div class="mb-3">
                        <input asp-for="Name" class="form-control" placeholder="Назва страви" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Description" class="form-control" placeholder="Опис" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Ціна" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="ImageFile" type="file" class="form-control" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/Dish" class="btn btn-outline-secondary">
                            ← Назад
                        </a>

                        <button type="submit" class="btn btn-pink">
                            Створити
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>