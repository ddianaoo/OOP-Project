@model List<Dish>

<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🍽 Страви</h2>

        <a asp-action="Create" class="btn btn-pink">
            <i class="bi bi-plus"></i> Додати
        </a>
    </div>

    <!-- Table Card -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Страва</th>
                        <th>Ціна</th>
                        <th class="text-end pe-4">Дії</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>

                            <!-- Dish -->
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">

                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl"
                                             style="width:50px;height:50px;object-fit:cover;border-radius:10px;" />
                                    }
                                    else
                                    {
                                        <div style="width:50px;height:50px;background:#eee;border-radius:10px;"></div>
                                    }

                                    <div>
                                        <div class="fw-semibold">@item.Name</div>

                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <small class="text-muted">
                                                @item.Description
                                            </small>
                                        }
                                    </div>

                                </div>
                            </td>

                            <!-- Price -->
                            <td>
                                <span class="fw-semibold">
                                    @item.Price.ToString("0.00") ₴
                                </span>
                            </td>

                            <!-- Actions -->
                            <td class="text-end pe-4">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-light border me-2">

                                    <i class="bi bi-pencil text-warning"></i>

                                </a>
                                <button class="btn btn-sm btn-light border"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-id="@item.Id"
                                        data-name="@item.Name">

                                    <i class="bi bi-trash text-danger"></i>

                                </button>

                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">

                <div class="modal-header text-danger border-0">
                    <h5 class="modal-title"><i class="bi bi-exclamation-diamond-fill"></i> Підтвердження</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center">
                    <p class="mb-2">Ви дійсно хочете видалити: <span id="dishName" class="fw-bold"></span> ?</p>
                </div>

                <div class="modal-footer border-0 justify-content-end">

                    <form id="deleteForm" method="post">
                        <input type="hidden" name="id" id="dishId" />

                        <button type="button"
                                class="btn btn-outline-secondary me-2"
                                data-bs-dismiss="modal">
                            Скасувати
                        </button>

                        <button type="submit" class="btn btn-danger">
                             Видалити
                        </button>
                    </form>

                </div>

            </div>
        </div>
    </div>
</div>

<script>
    const deleteModal = document.getElementById('deleteModal');

    deleteModal.addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;

        const id = button.getAttribute('data-id');
        const name = button.getAttribute('data-name');

        document.getElementById('dishId').value = id;
        document.getElementById('dishName').textContent = name;

        document.getElementById('deleteForm').action = '/Dish/Delete/' + id;
    });
</script>